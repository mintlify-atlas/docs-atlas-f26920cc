  "keyFeatures": [
    "Self-hosted digital library management",
    "Full EPUB support with built-in reader",
    "Multi-tenant architecture with organizations",
    "Advanced full-text search with Elasticsearch",
    "Japanese language support with kuromoji tokenizer",
    "Automatic metadata extraction and enrichment",
